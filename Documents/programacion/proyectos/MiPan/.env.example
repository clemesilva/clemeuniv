# Obtén URL y anon/public key en Supabase → Project Settings → API
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_anon_key

# Google OAuth (configuración en dashboards, no hacen falta más variables aquí):
# 1) Supabase → Authentication → URL configuration:
#    Site URL: http://localhost:5173 (y en prod tu dominio)
#    Redirect URLs: incluye http://localhost:5173/auth/callback (y en prod la misma ruta)
# 2) Supabase → Authentication → Providers → Google: Client ID y Secret (de Google Cloud)
# 3) Google Cloud Console → APIs y servicios → Credenciales → OAuth 2.0:
#    URI de redirección autorizada: https://TU_REF.supabase.co/auth/v1/callback
